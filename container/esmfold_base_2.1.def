Bootstrap: localimage
From: /nfs/ml_lab/projects/ml_lab/cepi/alphafold/images/cuda_11.3.1-devel-ubuntu20.04.sif

%post
    echo "Building ESMFold 2.0 with Ubuntu 20.04 + CUDA 11.3.1 + PyTorch 1.12.1"

    # Set non-interactive frontend to avoid prompts
    export DEBIAN_FRONTEND=noninteractive
    export TZ=America/Chicago
    ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone

    # Update package manager and install system dependencies
    apt-get update && apt-get install -y \
        python3 \
        python3-dev \
        python3-pip \
        python3-distutils \
        wget \
        git \
        curl \
        build-essential \
        software-properties-common \
        && apt-get clean \
        && rm -rf /var/lib/apt/lists/*

    # Set Python 3 as default python
    update-alternatives --install /usr/bin/python python /usr/bin/python3 1

    # Get and Install Miniconda
    MINICONDA_VERSION=py39_4.12.0
    MINICONDA_INSTALLER=Miniconda3-$MINICONDA_VERSION-Linux-x86_64.sh
    MINICONDA_PREFIX=/opt/miniconda
    wget --quiet https://repo.anaconda.com/miniconda/$MINICONDA_INSTALLER -O /tmp/$MINICONDA_INSTALLER
    bash /tmp/$MINICONDA_INSTALLER -b -p $MINICONDA_PREFIX
    rm /tmp/$MINICONDA_INSTALLER
    export PATH="$MINICONDA_PREFIX/bin:$PATH"
    echo "export PATH=$MINICONDA_PREFIX/bin:\$PATH" >> /etc/profile.d/conda.sh
    $MINICONDA_PREFIX/bin/conda init bash
    $MINICONDA_PREFIX/bin/conda clean -afy

        # Create and activate conda environment with latest Python and pip
        $MINICONDA_PREFIX/bin/conda create -y -n esmfold python=3.10 pip
        source $MINICONDA_PREFIX/bin/activate esmfold
        conda activate esmfold
        python -m pip install --upgrade pip setuptools

        # Install PyTorch 1.12.1 with CUDA 11.3 support in conda env
        python -m pip install --no-cache-dir \
            torch==1.12.1+cu113 \
            torchvision==0.13.1+cu113 \
            torchaudio==0.12.1 \
            --extra-index-url https://download.pytorch.org/whl/cu113

        # Install core dependencies from ESMFold environment.yml in conda env
        python -m pip install --no-cache-dir \
            'biopython==1.79' \
            'deepspeed==0.5.9' \
            'dm-tree==0.1.6' \
            'ml-collections==0.1.0' \
            'numpy==1.21.2' \
            'PyYAML==5.4.1' \
            'requests==2.26.0' \
            'scipy==1.7.1' \
            'tqdm==4.62.2' \
            'typing-extensions==3.10.0.2' \
            'pytorch_lightning>=1.5,<1.6' \
            'wandb==0.12.21' \
            'omegaconf' \
            'einops' \
            'fairscale'

        # Install additional scientific packages in conda env
        python -m pip install --no-cache-dir \
            'pandas' \
            'pytest'

        # Clone ESM repository and install from source in conda env
        cd /opt
        git clone https://github.com/facebookresearch/esm.git
        cd esm
        python -m pip install --no-cache-dir -e ".[esmfold]"

        # Install dllogger in conda env
        python -m pip install --no-cache-dir 'dllogger @ git+https://github.com/NVIDIA/dllogger.git'

        # Try to install OpenFold with CUDA compilation in conda env
        echo "Installing OpenFold with CUDA support..."
        python -m pip install --no-cache-dir \
            'openfold @ git+https://github.com/aqlaboratory/openfold.git@4b41059694619831a7db195b7e0988fc4ff3a307' || \
            echo "WARNING: OpenFold installation failed, ESMFold may work without it"

        # Create directories for models and data
        mkdir -p /data/models /data/input /data/output
        mkdir -p /models/torch/hub

        # Test ESMFold installation in conda env
        echo "Testing ESMFold installation..."
        python -c "import esm; print('ESM imported successfully')"
        python -m esm-fold --help || echo "ESMFold CLI test completed"

    # Upgrade pip
    python3 -m pip install --upgrade pip setuptools==59.5.0

    # Install PyTorch 1.12.1 with CUDA 11.3 support (exact ESMFold requirements)
    python3 -m pip install --no-cache-dir \
        torch==1.12.1+cu113 \
        torchvision==0.13.1+cu113 \
        torchaudio==0.12.1 \
        --extra-index-url https://download.pytorch.org/whl/cu113

    # Install core dependencies from ESMFold environment.yml
    python3 -m pip install --no-cache-dir \
        'biopython==1.79' \
        'deepspeed==0.5.9' \
        'dm-tree==0.1.6' \
        'ml-collections==0.1.0' \
        'numpy==1.21.2' \
        'PyYAML==5.4.1' \
        'requests==2.26.0' \
        'scipy==1.7.1' \
        'tqdm==4.62.2' \
        'typing-extensions==3.10.0.2' \
        'pytorch_lightning>=1.5,<1.6' \
        'wandb==0.12.21' \
        'omegaconf' \
        'einops' \
        'fairscale'

    # Install additional scientific packages
    python3 -m pip install --no-cache-dir \
        'pandas' \
        'pytest'

    # Clone ESM repository and install from source
    # This ensures we get the esm-fold command-line tool
    cd /opt
    git clone https://github.com/facebookresearch/esm.git
    cd esm

    # Install ESM with esmfold extras
    python3 -m pip install --no-cache-dir -e ".[esmfold]"

    # Install dllogger
    python3 -m pip install --no-cache-dir 'dllogger @ git+https://github.com/NVIDIA/dllogger.git'

    # Try to install OpenFold with CUDA compilation
    echo "Installing OpenFold with CUDA support..."
    python3 -m pip install --no-cache-dir \
        'openfold @ git+https://github.com/aqlaboratory/openfold.git@4b41059694619831a7db195b7e0988fc4ff3a307' || \
        echo "WARNING: OpenFold installation failed, ESMFold may work without it"

    # Create directories for models and data
    mkdir -p /data/models /data/input /data/output
    mkdir -p /models/torch/hub

    # Test ESMFold installation
    echo "Testing ESMFold installation..."
    python3 -c "import esm; print('ESM imported successfully')"
    python3 -m esm-fold --help || echo "ESMFold CLI test completed"

%environment
    # Set CUDA and PyTorch environment
    export PATH=/usr/local/cuda-11.3/bin:$PATH
    export LD_LIBRARY_PATH=/usr/local/cuda-11.3/lib64:$LD_LIBRARY_PATH
    export CUDA_HOME=/usr/local/cuda-11.3

    # ESMFold specific environment
    export ESMFOLD_MODEL_DIR=/data/models
    export TORCH_HOME=/models/torch
    export TORCH_HUB=/models/torch/hub
    export PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:512

    # Python environment
    export PYTHONPATH=/opt/esm:$PYTHONPATH

    # Ensure Python 3 is used
    export PATH=/usr/bin:$PATH

    # Language settings
    export LC_ALL=C

%runscript
    # Run esm-fold with provided arguments
    exec python3 -m esm-fold "$@"

%test
    echo "Testing ESMFold 2.0 container environment..."

    # Test Python version
    python3 --version

    # Test PyTorch installation and CUDA
    python3 -c "import torch; print(f'PyTorch: {torch.__version__}'); print(f'CUDA available: {torch.cuda.is_available()}'); print(f'CUDA version: {torch.version.cuda}')"

    # Test ESM import
    python3 -c "import esm; print('ESM imported successfully')"

    # Test esm-fold help
    python3 -m esm-fold --help

    echo "Container tests completed successfully"

%labels
    Author BV-BRC
    Application ESMFold
    Version 2.0.0
    Base nvidia/cuda:11.3.1-devel-ubuntu20.04
    PyTorch 1.12.1
    CUDA 11.3.1
    GLIBC 2.31
    Description ESMFold 2.0 with Ubuntu 20.04 for PATRIC runtime compatibility

%help
    ESMFold 2.0 Protein Structure Prediction Container

    Built on Ubuntu 20.04 with GLIBC 2.31 for PATRIC runtime compatibility.
    Includes PyTorch 1.12.1 with CUDA 11.3.1 support.

    Usage:
        # Basic structure prediction
        singularity run --nv container.sif -i input.fasta -o output_dir

        # With custom parameters
        singularity run --nv container.sif \
            -i input.fasta \
            -o output_dir \
            --num-recycles 4 \
            --chunk-size 128

    Options:
        -i, --fasta             Input FASTA file with protein sequences
        -o, --pdb               Output directory for PDB files
        --num-recycles          Number of recycles (0-4, default: 4)
        --chunk-size            Chunk size for processing (default: 128)
        --max-tokens-per-batch  Maximum tokens per batch (default: 1024)
        --cpu-only              Run on CPU only (no GPU)
        --cpu-offload           Offload to CPU for memory efficiency

    Features:
        - ESMFold from Meta's ESM repository
        - OpenFold integration with CUDA compilation
        - PyTorch 1.12.1 with CUDA 11.3.1
        - GLIBC 2.31 for PATRIC compatibility
        - Optimized for V100/A100 GPUs

    Environment:
        - Python 3.8 (Ubuntu 20.04 default)
        - PyTorch 1.12.1 + CUDA 11.3.1
        - ESM installed from source
        - Model cache: /models/torch/hub
        - Data directories: /data/{models,input,output}