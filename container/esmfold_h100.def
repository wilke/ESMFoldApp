Bootstrap: docker
From: pytorch/pytorch:2.0.1-cuda11.7-cudnn8-devel

%post
    # Install system dependencies
    apt-get update && apt-get install -y \
        wget \
        git \
        curl \
        && apt-get clean \
        && rm -rf /var/lib/apt/lists/*

    # Clone ESM repository and install from source
    # This ensures we get the esm-fold command-line tool
    cd /opt
    git clone https://github.com/facebookresearch/esm.git
    cd esm
    
    # Install ESM with esmfold extras
    pip install --no-cache-dir -e ".[esmfold]"
    
    # Install additional dependencies
    pip install --no-cache-dir 'dllogger @ git+https://github.com/NVIDIA/dllogger.git'
    
    # Try to install OpenFold, but continue if it fails (needs CUDA dev tools)
    pip install --no-cache-dir 'openfold @ git+https://github.com/aqlaboratory/openfold.git@4b41059694619831a7db195b7e0988fc4ff3a307' || \
        echo "OpenFold installation failed (needs CUDA dev tools), continuing without it..."
    
    # Create directories for input/output
    mkdir -p /data/input /data/output /data/models

%environment
    export ESMFOLD_MODEL_DIR=/data/models
    export PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:512
    export PATH=/opt/conda/bin:$PATH

%runscript
    exec /opt/conda/bin/esm-fold "$@"

%labels
    Author BV-BRC
    Name ESMFold H100
    Version 2.0.0

%help
    ESMFold protein structure prediction container for H100 GPUs.
    Built on PyTorch 2.0.1 with CUDA 11.7 support for sm_90 architecture.
    
    Usage:
        apptainer run --nv esmfold_h100.sif -i input.fasta -o output_dir
    
    Options:
        -i, --input             Input FASTA file with protein sequences
        -o, --output            Output directory for PDB files
        --num-recycles          Number of recycles (0-4, default: 4)
        --chunk-size            Chunk size for processing (default: 128)
        --max-tokens-per-batch  Maximum tokens per batch (default: 1024)
        --cpu-only              Run on CPU only (no GPU)
        --cpu-offload           Offload to CPU for memory efficiency
    
    Note: Use --nv flag for GPU acceleration.
    
    The container includes the official ESM repository installed from source,
    providing the esm-fold command-line tool from Meta.