Bootstrap: localimage
From: /nfs/ml_lab/projects/ml_lab/cepi/alphafold/images/cuda_11.3.1-devel-ubuntu20.04-050918.sif

%post

    # Get and Install Miniconda
    MINICONDA_VERSION=py39_25.7.0-2
    MINICONDA_INSTALLER=Miniconda3-$MINICONDA_VERSION-Linux-x86_64.sh
    # https://repo.anaconda.com/miniconda/Miniconda3-py39_25.7.0-2-Linux-x86_64.sh
    MINICONDA_PREFIX=/opt/miniconda
    wget --quiet https://repo.anaconda.com/miniconda/$MINICONDA_INSTALLER -O /tmp/$MINICONDA_INSTALLER
    bash /tmp/$MINICONDA_INSTALLER -b -p $MINICONDA_PREFIX
    rm /tmp/$MINICONDA_INSTALLER
    export PATH="$MINICONDA_PREFIX/bin:$PATH"
    echo "export PATH=$MINICONDA_PREFIX/bin:\$PATH" >> /etc/profile.d/conda.sh
    $MINICONDA_PREFIX/bin/conda init bash
    $MINICONDA_PREFIX/bin/conda clean -afy

    $MINICONDA_PREFIX/bin/conda tos accept --override-channels --channel https://repo.anaconda.com/pkgs/main
    $MINICONDA_PREFIX/bin/conda tos accept --override-channels --channel https://repo.anaconda.com/pkgs/r

    # Create and activate conda environment with latest Python and pip
    # $MINICONDA_PREFIX/bin/conda create -y -n esmfold python=3.10 pip
    # Do not activate the environment in %post; instead, use conda run for environment-specific commands
    # Example: $MINICONDA_PREFIX/bin/conda run -n esmfold python --version

    # Update pip inside the conda env
    # $MINICONDA_PREFIX/bin/conda run -n esmfold python -m pip install --upgrade pip setuptools


%environment

    export MINICONDA_PREFIX=/opt/miniconda/
    export PATH=$MINICONDA_PREFIX/bin:$PATH
    . /opt/miniconda/etc/profile.d/conda.sh